FROM python:3.11-slim
WORKDIR /app
RUN pip install --no-cache-dir faiss-cpu sentence-transformers langchain langchain-community qdrant-client uvicorn httpx openai python-dotenv fastapi
COPY rag_service/ /app/rag_service/
WORKDIR /app/rag_service
ENV LLM_PROVIDER="openai"
EXPOSE 8080
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8080"]

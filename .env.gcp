# Copy this to .env for local dev, set as Cloud Run secrets for prod

# GCP Project
GCP_PROJECT_ID=your-project-id
GCP_REGION=asia-south1

# Cloud SQL (local dev uses standard URL, Cloud Run uses socket)
DATABASE_URL=postgresql+asyncpg://soham:password@localhost:5432/news_bias_db

# Cloud Storage
GCS_BUCKET=news-bias-pdfs-your-project-id

# LLM Provider
LLM_PROVIDER=ollama   # local: ollama | gcp: openai

# Auth
SECRET_KEY=your-super-secret-key
ALGORITHM=HS256

# OpenAI (only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
